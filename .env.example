APP_NAME=Plataforma de Supervision de Campo API
ENVIRONMENT=development
DEBUG=false
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

POSTGRES_USER=supervision_user
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_DB=supervision_campo
POSTGRES_PORT=5432

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=replace-with-strong-minio-secret
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_SECURE=false
MINIO_REGION=us-east-1
MINIO_ATTACHMENTS_BUCKET=field-attachments
MINIO_REPORTS_BUCKET=report-exports
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_TRANSCRIPTION_MODEL=gemini-2.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
USE_MOCK_LLM=true

JWT_SECRET_KEY=replace-with-a-64-char-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=1440

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_FULL_NAME=Administrador de Plataforma
SEED_DEMO_EMAIL=demo@example.com
SEED_DEMO_PASSWORD=Demo123!
SEED_DEMO_FULL_NAME=Usuario Demo

BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1